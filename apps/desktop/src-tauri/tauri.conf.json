{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sports AI Video Editor",
  "version": "0.1.0",
  "identifier": "com.sve.editor",
  "build": {
    "frontendDist": "../../editor/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @sve/editor dev",
    "beforeBuildCommand": "pnpm --filter @sve/editor build"
  },
  "app": {
    "windows": [
      {
        "title": "Sports AI Video Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
